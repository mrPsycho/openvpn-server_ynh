#!/bin/bash

# Source YunoHost helpers
source /usr/share/yunohost/helpers

# Source common script
source _common.sh

#=================================================
# RETRIEVE ARGUMENTS
#=================================================

port=$YNH_APP_ARG_PORT
protocol=$YNH_APP_ARG_PROTOCOL
default_route=$YNH_APP_ARG_DEFAULT_ROUTE
dns_provider=$YNH_APP_ARG_DNS_PROVIDER
custom_dns=${YNH_APP_ARG_CUSTOM_DNS:-}

if [ "$dns_provider" == "google" ]; then
    dns_list="8.8.8.8 8.8.4.4"
elif [ "$dns_provider" == "custom" ]; then
    dns_list=$(echo "$custom_dns" | tr ',' ' ')
fi

# Save variables
ynh_app_setting_set --app=$app --key=port --value=$port
ynh_app_setting_set --app=$app --key=protocol --value=$protocol
ynh_app_setting_set --app=$app --key=default_route --value=$default_route
ynh_app_setting_set --app=$app --key=dns_provider --value="$dns_provider"
ynh_app_setting_set --app=$app --key=custom_dns --value="$custom_dns"


#=================================================
# CHECK AND PREPARE
#=================================================

ynh_script_progression "Preparing installation..."

# Create directories
mkdir -p "$ovpn_dir"
mkdir -p "$easy_rsa_dir"

#=================================================
# SETUP EASY-RSA AND CERTIFICATES
#=================================================
ynh_script_progression "Generating certificates..."

# Init PKI
rm -rf "$easy_rsa_dir"
make-cadir "$easy_rsa_dir"
cd "$easy_rsa_dir"
./easyrsa init-pki

# Build CA (without passphrase)
EASYRSA_BATCH=1 ./easyrsa build-ca nopass

# Generate server cert and key
EASYRSA_BATCH=1 ./easyrsa build-server-full server nopass

# Generate DH parameters
EASYRSA_BATCH=1 ./easyrsa gen-dh

# Generate TLS auth key
openvpn --genkey secret "$ovpn_dir/ta.key"

# Copy generated keys to server dir
cp pki/ca.crt "$ovpn_dir/"
cp pki/private/server.key "$ovpn_dir/"
cp pki/issued/server.crt "$ovpn_dir/"
cp pki/dh.pem "$ovpn_dir/"

# Set permissions
chmod 600 "$ovpn_dir/server.key"
chmod 600 "$ovpn_dir/ta.key"

#=================================================
# CONFIGURE OPENVPN AND LDAP
#=================================================
ynh_script_progression "Configuring OpenVPN..."

# Generate OpenVPN server configuration
ynh_config_add --template="server.conf.j2" --destination="$ovpn_dir/server.conf"
ynh_config_add --template="auth-ldap.conf.j2" --destination="$ovpn_dir/auth-ldap.conf"

# Change permissions
chown -R root:root "$ovpn_dir"

# Configure Firewall
ynh_script_progression "Configuring firewall..."
# ynh_port_add --port "$port" --protocol "$protocol"

# Setup NAT / Routing
mkdir -p /etc/openvpn/scripts
ynh_config_add --template="route-up.sh.j2" --destination="/etc/openvpn/scripts/route-up-$app.sh"
ynh_config_add --template="route-down.sh.j2" --destination="/etc/openvpn/scripts/route-down-$app.sh"
chmod +x /etc/openvpn/scripts/route-up-$app.sh
chmod +x /etc/openvpn/scripts/route-down-$app.sh

# Enable IP forwarding
echo "net.ipv4.ip_forward = 1" > /etc/sysctl.d/99-openvpn-$app.conf
sysctl -p /etc/sysctl.d/99-openvpn-$app.conf

#=================================================
# SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting OpenVPN service..."

# Enable and start service
systemctl enable openvpn-server@$app
# systemctl start openvpn-server@$app

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Installation completed"
