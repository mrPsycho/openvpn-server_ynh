#!/bin/bash

# Source YunoHost helpers
source /usr/share/yunohost/helpers

# Source common script
source _common.sh

ynh_script_progression "Upgrading OpenVPN service..."

# Retrieve current settings
port=$(ynh_app_setting_get --app=$app --key=port)
protocol=$(ynh_app_setting_get --app=$app --key=protocol)
default_route=$(ynh_app_setting_get --app=$app --key=default_route)
dns_provider=$(ynh_app_setting_get --app=$app --key=dns_provider)
custom_dns=$(ynh_app_setting_get --app=$app --key=custom_dns)
domain=$(ynh_app_setting_get --app=$app --key=domain)

if [ "$dns_provider" == "google" ]; then
    dns_list="8.8.8.8 8.8.4.4"
elif [ "$dns_provider" == "custom" ]; then
    dns_list=$(echo "$custom_dns" | tr ',' ' ')
fi

# Install apt dependencies
ynh_install_app_dependencies $YNH_APP_DEPENDENCIES

# Read certificate content for inline bundling
ca_cert=$(cat "$ovpn_dir/ca.crt")
server_cert=$(cat "$ovpn_dir/server.crt")
server_key=$(cat "$ovpn_dir/server.key")
dh_params=$(cat "$ovpn_dir/dh.pem")

if [ "$default_route" = "1" ]; then
    default_route_line='push "redirect-gateway def1 bypass-dhcp"'
else
    default_route_line=""
fi

dns_list_lines=""
for dns in $dns_list; do
    dns_list_lines="${dns_list_lines}push \"dhcp-option DNS $dns\"\n"
done

# Generate server.conf manually
cat > "$ovpn_dir/server.conf" << EOF
port $port
proto $protocol
dev tun
<ca>
$ca_cert
</ca>
<cert>
$server_cert
</cert>
<key>
$server_key
</key>
<dh>
$dh_params
</dh>

server 10.8.0.0 255.255.255.0
ifconfig-pool-persist ipp.txt

$default_route_line

$dns_list_lines
keepalive 10 120
tls-auth $ovpn_dir/ta.key 0
cipher AES-256-GCM

user nobody
group nogroup

persist-key
persist-tun

status /var/log/openvpn/openvpn-status.log
log-append /var/log/openvpn/openvpn.log
verb 3
explicit-exit-notify 1

plugin /usr/lib/openvpn/openvpn-auth-ldap.so $ovpn_dir/auth-ldap.conf
verify-client-cert none
username-as-common-name

script-security 2
route-up /etc/openvpn/scripts/route-up-$app.sh
route-pre-down /etc/openvpn/scripts/route-down-$app.sh
EOF

# Regenerate client config
cat > "$ovpn_dir/openvpn.conf" << EOF
client
dev tun
proto $protocol
remote $domain $port
resolv-retry infinite
nobind
persist-key
persist-tun
<ca>
$ca_cert
</ca>
tls-auth $ovpn_dir/ta.key 1
remote-cert-tls server
cipher AES-256-GCM
auth SHA256
verb 3
auth-user-pass
EOF

ynh_config_add --template="auth-ldap.conf.j2" --destination="$ovpn_dir/auth-ldap.conf"

ynh_config_add --template="route-up.sh.j2" --destination="/etc/openvpn/scripts/route-up-$app.sh"
ynh_config_add --template="route-down.sh.j2" --destination="/etc/openvpn/scripts/route-down-$app.sh"

chown -R root:root "$ovpn_dir"
chmod +x /etc/openvpn/scripts/route-up-$app.sh
chmod +x /etc/openvpn/scripts/route-down-$app.sh

# Restart service
systemctl daemon-reload
systemctl restart openvpn-server@$app

ynh_script_progression "Upgrade completed"
